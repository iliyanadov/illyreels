# ===========================================
# IllyReels Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# ===========================================
# Instagram / Meta OAuth
# ===========================================
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/meta/callback
META_GRAPH_VERSION=v22.0

# ===========================================
# Google OAuth
# ===========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# ===========================================
# DFlow Prediction Markets API
# ===========================================
DFLOW_API_KEY=your_dflow_api_key
DFLOW_API_URL=https://c.prediction-markets-api.dflow.net

# ===========================================
# Vercel Blob Storage
# ===========================================
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# ===========================================
# Error Tracking (Sentry)
# ===========================================
# Get these from https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@o1234.ingest.sentry.io/123456
SENTRY_DSN=https://xxxxx@o1234.ingest.sentry.io/123456
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_org_slug
SENTRY_PROJECT=your_project_slug

# ===========================================
# Optional: Google Sheets Default
# ===========================================
DEFAULT_SPREADSHEET_ID=your_default_sheet_id
DEFAULT_SHEET_NAME=Sheet1
